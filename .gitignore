# servroot is typically the nginx/Kong workingdirectory when testing
servroot

# packed distribution format for LuaRocks
*.rock
# exclude Pongo shell history
.pongo/.ash_history
.pongo/.bash_history
# exclude LuaCov statistics file
luacov.stats.out
# exclude LuaCov reports
luacov.report.out
luacov.report.html
# exclude Pongo containerid file
.containerid

# ローカル専用の内部資料（仕様調査ノート・設計書・実装計画はコミットしない）
# docs/ 直下のユーザーガイド（docs/*.md）はコミット対象
docs/obo/
docs/superpowers/
.superpowers/

# ローカル検証用の実値ファイル（example のみコミットする）
.env

# Konnect データプレーンの cluster 証明書・秘密鍵（絶対にコミットしない）
cluster-certs/
