# ローカル検証用の環境変数。cp .env.example .env して記入する（.env は gitignore 済み）

# Konnect データプレーンの接続先プレフィックス（Gateway Manager の DP 接続情報から）
PREFIX=

# obo プラグインの client_secret 方式:
# Konnect で設定するプラグイン config の client_secret に
# "{vault://env/obo-client-secret}" を指定すると、DP 上でこの環境変数から解決される
OBO_CLIENT_SECRET=

# private_key_jwt 方式の秘密鍵（PEM）は複数行のため .env では渡せない。
# ホストのシェルで以下を実行してから docker compose up すること:
#   export OBO_PRIVATE_KEY_PEM="$(cat /path/to/private-key.pem)"
# （プラグイン config 側は private_key: "{vault://env/obo-private-key-pem}" を指定）
