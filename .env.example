# =============================================================================
# kong-plugin-obo ローカル検証用の環境変数
# 使い方: cp .env.example .env して記入する（.env は gitignore 済み。コミット禁止）
# 各値の取得方法は docs/ のガイド 01〜04 を参照
# =============================================================================

# --- Konnect データプレーン接続（docs/02） ---
# Gateway Manager の DP 接続 URL のプレフィックス
# （https://<PREFIX>.us.cp0.konghq.com の <PREFIX> 部分。例: 68f6ad0a51）
PREFIX=

# --- Konnect API / deck（docs/01, 04。mise タスクが使用） ---
# Konnect のパーソナルアクセストークン（kpat_ で始まる）
DECK_KONNECT_TOKEN=
# 対象の Control Plane 名（例: local-gateway）
DECK_KONNECT_CONTROL_PLANE_NAME=

# --- obo プラグインの設定値（docs/03 §5 の対応表参照。examples/kong.yaml から参照される） ---
# Entra ID のテナント ID（GUID）
DECK_TENANT_ID=
# middle-tier アプリ（Kong を表すアプリ登録）の Application (client) ID
DECK_CLIENT_ID=
# middle-tier アプリのクライアントシークレットの Value
DECK_CLIENT_SECRET=
# downstream API のスコープのフル文字列（例: api://<downstream-client-id>/Data.Read）
DECK_SCOPE=
# 受信トークン（token A）の aud 期待値。v2.0 トークンでは通常 DECK_CLIENT_ID と同じ素の GUID
DECK_AUDIENCE=

# --- 補足 ---
# シークレットは deck の環境変数置換（上記 DECK_CLIENT_SECRET）により
# gateway:sync 実行時に Konnect へ登録される。
# シークレットを Konnect 側に保存したくない場合は、examples/kong.yaml の client_secret を
# リテラル文字列 "{vault://env/obo-client-secret}" にし、compose.yaml の kong サービスに
# 環境変数 OBO_CLIENT_SECRET を渡す構成（Kong の env vault）に変更することもできる。
